# ─────────────────────────────────────────────────────────────
# Community Bridge — environment configuration
# Copy this file to `.env` (`cp .env.example .env`) and adjust as needed.
# docker compose reads `.env` automatically.
# ─────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────
NODE_ENV=development

# ── Host ports ───────────────────────────────────────────────
# Host-side ports mapped to the containers. Change if these clash locally.
BACKEND_PORT=4000
FRONTEND_PORT=5173
POSTGRES_PORT=5432

# ── Database (PostgreSQL + pgvector) ─────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=community_bridge
# Full connection string used by the backend. Inside docker compose the host is
# the service name `postgres`; when running the backend directly, use localhost:
#   postgres://postgres:postgres@localhost:5432/community_bridge
DATABASE_URL=postgres://postgres:postgres@postgres:5432/community_bridge

# ── Auth (JWT) ───────────────────────────────────────────────
# Auth is token-based (JWT bearer), NOT session cookies — cookies break inside
# third-party embeds. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# Today this is just our standalone frontend. THIS MATTERS FOR THE EMBED MODEL:
# if/when we ship the embeddable widget, every host community's domain that
# embeds it must be added here (or this becomes a per-org allowlist).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend ─────────────────────────────────────────────────
# Base URL the frontend uses to reach the API (Vite exposes VITE_* to the app).
VITE_API_BASE_URL=http://localhost:4000

# ── AI service (report clustering — Insights tier) ───────────
# Anthropic API key used by AI report clustering + urgency triage.
# Get one at https://console.anthropic.com/settings/keys
# Leave the placeholder to run without AI: everything else works; the AI
# triage endpoint returns 503 until a real key is set.
AI_API_KEY=your-ai-api-key-here
