# ─────────────────────────────────────────────────────────────
# Community Bridge — environment configuration
#
# Copy this file to `.env` (`cp .env.example .env`) and fill in the values.
# `docker compose` reads `.env` automatically for local development.
#
# For PRODUCTION you set these as environment variables in each platform's
# dashboard (NOT by committing a .env): the backend vars in Railway, and the
# VITE_* frontend vars in Vercel. See the section notes below for which go where.
# ─────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────
# `development` locally; set to `production` on Railway. Controls logging/behaviour
# and (via the connection string) whether the DB connects over TLS.
NODE_ENV=development

# ── Host ports (local docker compose only) ───────────────────
# Host-side ports mapped to the containers. Change if these clash locally.
# Not used in production (Railway/Vercel assign ports themselves).
BACKEND_PORT=4000
FRONTEND_PORT=5173
# 5432 by default. On some machines a native PostgreSQL already owns 5432 —
# set 5433 (or any free port) here if `docker compose up` reports a port clash.
POSTGRES_PORT=5432

# ── Database — local (PostgreSQL + pgvector via docker compose) ──
# Credentials for the local postgres container. In production you don't use these;
# you use Supabase's connection string in DATABASE_URL below instead.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=community_bridge

# Full Postgres connection string the backend connects with.
#
#  • LOCAL (docker compose): the DB host is the compose service name `postgres`:
#      postgres://postgres:postgres@postgres:5432/community_bridge
#  • LOCAL (backend run directly, not in docker): use localhost:
#      postgres://postgres:postgres@localhost:5432/community_bridge
#  • PRODUCTION (Supabase): copy from Supabase dashboard →
#      Project Settings → Database → Connection string → "URI".
#      Use the connection POOLER string for a serverless-friendly connection.
#      It ends with `?sslmode=require`; the backend auto-enables TLS when it sees
#      that (or when DATABASE_SSL=true). Example shape:
#      postgres://postgres.<ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgres://postgres:postgres@postgres:5432/community_bridge

# Force TLS on the DB connection even if the URL has no `sslmode=require`.
# Leave unset locally; not normally needed for Supabase (its URL already asks for SSL).
# DATABASE_SSL=true

# ── Auth (JWT) ───────────────────────────────────────────────
# Secret used to sign/verify JWT bearer tokens. Auth is token-based (NOT session
# cookies — cookies break inside third-party embeds).
# Generate a long random value for production, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
# How long an issued token stays valid (e.g. 7d, 24h, 30m).
JWT_EXPIRES_IN=7d

# ── CORS (backend / Railway) ─────────────────────────────────
# Comma-separated list of origins allowed to call the API. The browser will be
# refused unless its origin is listed here.
#  • LOCAL: the Vite dev server.
#  • PRODUCTION: your deployed frontend URL(s) — the Vercel domain, plus any host
#    community domain that embeds the widget. No trailing slash. Example:
#      https://community-bridge.vercel.app,https://www.a-partner-mosque.org
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend → API base URL (Vercel) ─────────────────────────
# Base URL the frontend uses to reach the API. Vite inlines VITE_* vars at BUILD
# time, so set this in Vercel BEFORE building.
#  • LOCAL: http://localhost:4000
#  • PRODUCTION: your Railway backend's public URL, e.g. https://community-bridge-api.up.railway.app
VITE_API_BASE_URL=http://localhost:4000

# ── AI service — report clustering (Insights tier) ───────────
# Anthropic API key used by AI report clustering + urgency triage (backend only).
# Get one at https://console.anthropic.com/settings/keys
# Everything else runs without it; the AI triage endpoint returns 503 until set.
AI_API_KEY=your-ai-api-key-here

# ── Media storage — announcement images (Supabase Storage) ───
# The BACKEND uploads images with the SERVICE ROLE key, so these are secrets and
# must never be exposed to the browser (set them in Railway, not Vercel).
# Without them, image upload returns 503 but the rest of the app works.
#
# Supabase Project URL — Supabase dashboard → Project Settings → API → "Project URL".
#   e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL=
# Service Role key — Supabase dashboard → Project Settings → API → "service_role"
# (the SECRET key, not the anon key). Full admin access — keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=
# Name of the Storage bucket that holds uploaded images. Create it in the Supabase
# dashboard → Storage → New bucket, and mark it PUBLIC so the feed can render URLs.
SUPABASE_STORAGE_BUCKET=announcement-images

# ── Supabase Anon Key (reference) ────────────────────────────
# The public anon key is NOT needed by this codebase today (the backend mediates
# all Supabase access with the service role key). It's listed here only so you know
# where it lives if you later add direct browser→Supabase calls:
#   Supabase dashboard → Project Settings → API → "anon / public".
# SUPABASE_ANON_KEY=

# ── Railway (reference) ──────────────────────────────────────
# Railway injects PORT automatically; the backend reads it (defaults to 4000) —
# do not hard-code it. Set NODE_ENV=production and all the backend vars above
# (DATABASE_URL, JWT_SECRET, CORS_ALLOWED_ORIGINS, AI_API_KEY, SUPABASE_*) in the
# Railway service's Variables tab.
